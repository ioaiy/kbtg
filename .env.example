# --- HTTP server ---
APP_PORT=8080
APP_ENV=development                          # development | production
HTTP_READ_TIMEOUT_SECONDS=10
HTTP_WRITE_TIMEOUT_SECONDS=10
HTTP_IDLE_TIMEOUT_SECONDS=60
HTTP_SHUTDOWN_TIMEOUT_SECONDS=10

# --- Logging ---
LOG_LEVEL=info                               # debug | info | warn | error
LOG_FORMAT=json                              # json | text

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=skinport_test
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME_MINUTES=30
POSTGRES_QUERY_TIMEOUT_SECONDS=5

# --- Redis ---
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT_SECONDS=3
REDIS_OPERATION_TIMEOUT_SECONDS=2

# --- Skinport upstream ---
SKINPORT_BASE_URL=https://api.skinport.com
SKINPORT_TIMEOUT_SECONDS=10
SKINPORT_CACHE_TTL_SECONDS=60
SKINPORT_CACHE_STALE_TTL_SECONDS=600
DEFAULT_APP_ID=730
DEFAULT_CURRENCY=USD
